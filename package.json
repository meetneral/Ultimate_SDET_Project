  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongodb": "^7.1.1",
    "ollama": "^0.6.3",
    "openai": "^6.25.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
