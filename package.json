{
  "name": "playwright-template",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ai": "npx playwright test --grep 'Hybrid-test.spec' --project=chromium",
    "report:generate": "npx allure generate ./allure-results --clean -o ./allure-report",
    "report:open": "npx allure open ./allure-report",
    "allure": "npx allure serve ./allure-results",
    "clean": "rm -rf allure-results allure-report test-results"
  },
